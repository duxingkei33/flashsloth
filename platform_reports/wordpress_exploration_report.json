    ]
  },
  "adapter_status": {
    "publisher": "✅ plugins/publisher_wordpress.py — REST API 方式发布/存草稿/上传",
    "sdk_adapter": "✅ sdk/adapters/wordpress.py — 发布/预留采集",
    "login_plugin": "❌ 不需要（使用 REST API 应用密码认证，无需 Playwright）",
    "account_in_db": "❌ 无（需要用户提供站点 URL 和应用密码）",
