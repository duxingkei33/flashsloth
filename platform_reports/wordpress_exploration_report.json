      {"url": "/wp-json/wp/v2/media", "desc": "媒体上传与查询"},
      {"url": "/wp-json/wp/v2/pages", "desc": "页面管理"},
      {"url": "/wp-json/wp/v2/comments", "desc": "评论管理"},
